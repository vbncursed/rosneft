# Build artifacts
/bin/
/dist/

# Local data — blob storage now lives in a Docker named volume, so we
# don't need the host blob/ tracked at all. source/ stays as a bind
# mount but contains user-supplied .obj/.mtl/.jpg files that should
# never be committed; we only track the empty directory via .gitkeep
# so a fresh clone has the mount target ready.
/data/blob/
/data/source/*
!/data/source/.gitkeep
*.pid

# IDE
.idea/
.vscode/
*.swp

# Test
*.test
*.out
coverage.txt
coverage.html

# Env
.env
.env.local

# Generated proto code (uncomment if generated code should not be committed)
# /proto/gen/

# Docker
.docker-volume/
